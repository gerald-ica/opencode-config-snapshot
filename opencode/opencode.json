{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "/Users/wendyly/.agents/AGENTS.md",
    "/Users/wendyly/.config/opencode/OPENCODE.md"
  ],
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "google/gemma-3-4b": {
          "name": "Gemma 3 4B"
        },
        "nvidia-nemotron-3-super-120b-a12b-heretic-i1": {
          "name": "NVIDIA Nemotron 3 Super 120B A12B Heretic I1"
        },
        "qwen3.5-9b-unsloth-mlx": {
          "name": "Qwen3.5-9B Unsloth MLX"
        }
      }
    }
  },
  "model": "lmstudio/nvidia-nemotron-3-super-120b-a12b-heretic-i1",
  "plugin": [
    "oh-my-openagent"
  ],
  "agent": {
    "build": {
      "model": "lmstudio/nvidia-nemotron-3-super-120b-a12b-heretic-i1"
    },
    "plan": {
      "model": "lmstudio/nvidia-nemotron-3-super-120b-a12b-heretic-i1"
    },
    "general": {
      "model": "lmstudio/nvidia-nemotron-3-super-120b-a12b-heretic-i1"
    },
    "explore": {
      "model": "lmstudio/nvidia-nemotron-3-super-120b-a12b-heretic-i1"
    },
    "local-orchestrator": {
      "permission": {
        "task": {
          "*": "deny",
          "repo-scout": "allow",
          "framework-adapter": "allow",
          "review-gate": "allow",
          "general": "allow",
          "explore": "allow"
        }
      }
    }
  },
  "mcp": {
    "pencil": {
      "command": [
        "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
        "--app",
        "desktop"
      ],
      "enabled": true,
      "type": "local"
    },
    "gitnexus": {
      "command": [
        "node",
        "/Users/wendyly/.local/share/agent-skills/external/GitNexus/gitnexus/dist/cli/index.js",
        "mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "paper": {
      "type": "remote",
      "url": "http://127.0.0.1:29979/mcp",
      "enabled": true
    }
  }
}
